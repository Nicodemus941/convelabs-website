{
  "headers": [
    {
      "//": "Vite content-hashed bundles — safe to cache forever (filename changes when content changes).",
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "//": "SPA shell + service worker + manifest — never cache. Vercel's path-to-regexp does NOT support negative lookahead (commit fa40cca), so we enumerate explicit no-cache paths instead of /((?!assets/).*).",
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" }
      ]
    },
    {
      "//": "All SPA routes that rewrite to /index.html. Headers apply to the original requested path (pre-rewrite), so we must list them. Vercel CDN treats unlisted paths with default caching, but since the rewrite TARGET (/index.html) above is no-cache, the served HTML body will not be CDN-cached.",
      "source": "/book-now/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" }
      ]
    },
    {
      "source": "/dashboard/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" }
      ]
    },
    {
      "source": "/admin/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" }
      ]
    },
    {
      "source": "/staff/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" }
      ]
    },
    {
      "source": "/login",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" }
      ]
    },
    {
      "source": "/pricing",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" }
      ]
    },
    {
      "source": "/lab-request/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "patients.convelabs.com" }],
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "staff.convelabs.com" }],
      "destination": "/index.html"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
